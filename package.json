{
  "name": "katex-svelte",
  "version": "0.1.1",
  "description": "Svelte 5 wrapper for KaTeX — render LaTeX math and chemistry equations (mhchem) with \\ce{} notation",
  "keywords": [
    "svelte",
    "katex",
    "latex",
    "math",
    "chemistry",
    "mhchem",
    "chemical-equations",
    "svelte5",
    "runes",
    "equations"
  ],
  "homepage": "https://katex-svelte-docs.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/makeez-labs/katex-svelte"
  },
  "bugs": {
    "url": "https://github.com/makeez-labs/katex-svelte/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Makeez Labs",
    "url": "https://github.com/makeez-labs"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles": "./dist/katex.min.css"
  },
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite dev",
    "build": "svelte-package -i src/lib && cp node_modules/katex/dist/katex.min.css dist/",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "svelte-check --tsconfig tsconfig.json",
    "lint": "svelte-check && prettier --check \"src/**/*.{ts,svelte}\"",
    "format": "prettier --write \"src/**/*.{ts,svelte}\""
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "dependencies": {
    "katex": "^0.16.45"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@testing-library/svelte": "^5.3.1",
    "@types/katex": "^0.16.8",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.55.4",
    "svelte-check": "^4.4.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
